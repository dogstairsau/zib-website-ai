# Required — Anthropic key for the strategist read
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required for sample creative — OpenAI key (gpt-image-1-mini by default)
OPENAI_API_KEY=sk-proj-...

# Optional — override defaults (gpt-image-1-mini · 1024x1536 · medium)
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1024x1024
# OPENAI_IMAGE_QUALITY=high

# Optional — without it, PSI is rate-limited
PSI_API_KEY=

# Optional — without it, leads log to the function console only
HUBSPOT_PRIVATE_APP_TOKEN=

# Optional — for posting lead notifications to Slack
SLACK_WEBHOOK_URL=
